✅ Problem 2: Mobile Recharge System

class InvalidRechargeAmountException extends Exception {
    public InvalidRechargeAmountException(String message) {
        super(message);
    }
}

class MobileAccount {
    private double balance;

    public MobileAccount(double balance) {
        this.balance = balance;
    }

    public void recharge(double amount) throws InvalidRechargeAmountException {
        if (amount < 10) {
            throw new InvalidRechargeAmountException("Minimum recharge is 10 taka!");
        }
        balance += amount;
        System.out.println("Recharge successful.");
    }

    public void checkBalance() {
        System.out.println("Balance: " + balance);
    }
}

public class RechargeService {
    public static void main(String[] args) {
        MobileAccount acc = new MobileAccount(50);

        try {
            acc.recharge(5); // invalid
        } catch (InvalidRechargeAmountException e) {
            System.out.println(e.getMessage());
        }

        try {
            acc.recharge(20);
        } catch (Exception e) {}

        acc.checkBalance();
    }
}


