✅ Problem 5: Student Result Processing

class InvalidMarkException extends Exception {
    public InvalidMarkException(String msg) {
        super(msg);
    }
}

class Student {
    private int marks;

    public void setMarks(int marks) throws InvalidMarkException {
        if (marks < 0 || marks > 100) {
            throw new InvalidMarkException("Marks must be between 0 and 100!");
        }
        this.marks = marks;
    }

    public void calculateGrade() {
        if (marks >= 80) System.out.println("Grade: A");
        else if (marks >= 60) System.out.println("Grade: B");
        else if (marks >= 40) System.out.println("Grade: C");
        else System.out.println("Grade: F");
    }
}

public class ResultProcessor {
    public static void main(String[] args) {
        Student s = new Student();

        try {
            s.setMarks(120); // invalid
        } catch (InvalidMarkException e) {
            System.out.println(e.getMessage());
        }

        try {
            s.setMarks(75);
            s.calculateGrade();
        } catch (Exception e) {}
    }
}


