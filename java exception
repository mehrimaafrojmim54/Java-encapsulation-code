✅ Problem 1: Train Ticket Booking System

class SeatNotAvailableException extends Exception {
    public SeatNotAvailableException(String message) {
        super(message);
    }
}

class Train {
    private int availableSeats;

    public Train(int seats) {
        this.availableSeats = seats;
    }

    public void bookTicket(int seats) throws SeatNotAvailableException {
        if (seats > availableSeats) {
            throw new SeatNotAvailableException("Not enough seats available!");
        }
        availableSeats -= seats;
        System.out.println("Ticket booked successfully.");
    }

    public void checkAvailableSeats() {
        System.out.println("Available seats: " + availableSeats);
    }
}

public class TicketBookingSystem {
    public static void main(String[] args) {
        Train train = new Train(10);

        try {
            train.bookTicket(5);
            train.bookTicket(7); // will throw exception
        } catch (SeatNotAvailableException e) {
            System.out.println(e.getMessage());
        }

        train.checkAvailableSeats();
    }
}


