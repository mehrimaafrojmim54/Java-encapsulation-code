✅ Problem 6: Password Validation System

class WeakPasswordException extends Exception {
    public WeakPasswordException(String msg) {
        super(msg);
    }
}

class UserAccount {
    private String password;

    public void setPassword(String password) throws WeakPasswordException {
        validatePassword(password);
        this.password = password;
        System.out.println("Password set successfully.");
    }

    private void validatePassword(String password) throws WeakPasswordException {
        if (password.length() < 8) {
            throw new WeakPasswordException("Password must be at least 8 characters!");
        }
    }
}

public class RegistrationSystem {
    public static void main(String[] args) {
        UserAccount user = new UserAccount();

        try {
            user.setPassword("123"); // weak
        } catch (WeakPasswordException e) {
            System.out.println(e.getMessage());
        }

        try {
            user.setPassword("strong123");
        } catch (Exception e) {}
    }
}


